# SASA Payments Credentials
# Jisajili: https://sasapay.co.tz/business.html → Individual Registration
# Baada ya kusajiliwa, utapata hizi credentials kutoka kwa SASA

SASAPAY_CLIENT_ID=client_id_yako_hapa
SASAPAY_CLIENT_SECRET=client_secret_yako_hapa
SASAPAY_MERCHANT_CODE=merchant_code_yako_hapa
SASAPAY_ENV=sandbox  # sandbox au production

# Server
PORT=3000
FRONTEND_URL=http://localhost:3000
